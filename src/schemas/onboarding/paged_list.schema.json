{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.company.internal/onboarding/paged_list.schema.json",
  "title": "Onboarding - Paged List",
  "description": "Supports nested pagination envelope observed in /onboarding/paged.",
  "type": "object",
  "required": ["data"],
  "additionalProperties": true,
  "properties": {
    "data": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        {
          "type": "object",
          "required": ["data"],
          "additionalProperties": true,
          "properties": {
            "data": {
              "type": "array",
              "items": { "type": "object", "additionalProperties": true }
            },
            "totalPages": { "type": ["integer", "number"], "minimum": 0 },
            "totalElements": { "type": ["integer", "number"], "minimum": 0 }
          }
        }
      ]
    }
  }
}
