{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.caelius/hrmis/documents/status_list.schema.json",
  "title": "Documents Status List",
  "type": "object",
  "required": ["data"],
  "properties": {
    "message": { "type": ["string", "null"] },
    "data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["documentType", "documentName", "isUploaded"],
        "properties": {
          "documentType": { "type": "string" },
          "documentName": { "type": "string" },
          "isUploaded": { "type": "boolean" },
          "documentId": { "type": ["number", "integer", "null"] },
          "documentViewId": { "type": ["number", "integer", "null"] },
          "documentPath": { "type": ["string", "null"] },
          "isMandatory": { "type": ["boolean", "null"] },
          "approvalStatus": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
